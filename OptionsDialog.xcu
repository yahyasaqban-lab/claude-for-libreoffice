<?xml version="1.0" encoding="UTF-8"?>
<oor:component-data xmlns:oor="http://openoffice.org/2001/registry"
                    xmlns:xs="http://www.w3.org/2001/XMLSchema"
                    oor:name="OptionsDialog"
                    oor:package="org.openoffice.Office">
    <node oor:name="Nodes">
        <node oor:name="Claude" oor:op="replace">
            <prop oor:name="Label" oor:type="xs:string">
                <value xml:lang="en">Claude AI</value>
            </prop>
            <prop oor:name="AllModules" oor:type="xs:boolean">
                <value>true</value>
            </prop>
            <node oor:name="Leaves">
                <node oor:name="ClaudeSettings" oor:op="replace">
                    <prop oor:name="Id" oor:type="xs:string">
                        <value>com.anthropic.claude.settings</value>
                    </prop>
                    <prop oor:name="Label" oor:type="xs:string">
                        <value xml:lang="en">Settings</value>
                    </prop>
                </node>
            </node>
        </node>
    </node>
</oor:component-data>
